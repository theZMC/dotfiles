get_os_name() {
  if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if [ -f /etc/os-release ]; then
      # shellcheck disable=SC1091 # The /etc/os-release file is expected to be present on Linux systems
      . /etc/os-release
      echo "${ID,,}"
    else
      echo "linux_generic"
    fi
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    echo "darwin"
  else
    echo "unknown"
  fi
}

echo "${os_icons[$(get_os_name)]:-${os_icons[unknown]}}"
